rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuarios ───
    // Cada usuario puede leer y editar solo su propio perfil.
    // Los admins pueden leer todos los perfiles.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if false; // No se eliminan usuarios
    }

    // ─── Servicios ───
    // Lectura pública (para mostrar en la web).
    // Solo admins pueden crear, editar o eliminar servicios.
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // ─── Reservas ───
    // Cualquier usuario autenticado puede leer (necesario para verificar
    // horarios ocupados en la consulta de disponibilidad).
    // Solo el dueño de la reserva o un admin puede crear/editar.
    match /reservations/{reservationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }

    // ─── Configuración ───
    // config/mp contiene el token de Mercado Pago: solo usuarios autenticados.
    // config/bloqueos: también requiere auth (la reserva ya exige login de todas formas).
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── Productos (cremas) ───
    // Lectura pública para que cualquier visitante pueda ver el catálogo.
    // Solo admins pueden crear, editar o eliminar.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // ─── Pedidos de cremas ───
    // Similar a reservations: cualquier auth puede leer (para validaciones),
    // solo el dueño puede crear, dueño o admin pueden actualizar.
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }

    // ─── Función auxiliar: verificar si el usuario es admin ───
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }
  }
}
